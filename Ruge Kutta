#!/usr/bin/env wolframscript
RKODE[G_, x0_, f0_, dx_, Ns_] := Module [{k1, k2, retvals, index, xn, fn},
retvals = Table[{0.0, 0.0}, {i, 1, Ns}];
xn = x0;
fn = f0;
retvals[[1]] = {x0, f0};
For[index = 2, index <= Ns, index = index +1,
        k1 = dx G[xn, fn];
        k2 = dx G[xn + dx/2, fn + (k1/2)];
        fn = fn + k2;
        xn = xn + dx;
        retvals[[index]] = {xn, fn};
        ];
Return[retvals];
]

f[t_, x_]:= -2*x*t
x0=1.0;
f0=1.0;
dx=0.1;
Ns=50;
resultados = RKODE[f, x0, f0, dx, Ns];
Export["grafica.png", ListPlot[resultados,
 Joined -> True,
 Mesh -> All,
 AxesLabel -> {"Tiempo (t)", "x(t)"},
 PlotLabel -> "Solucion usando Runge-Kutta (Midpoint)",
 PlotStyle -> {Blue, Thick},
 MeshStyle -> Red]]
